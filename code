#include<iostream>
using namespace std;
class Student{
private:
int id;
string name;
public:
Student(int i,string n){
id = i;
name = n;
}
void display(){
  cout<<"ID: "<<id<<endl;
  cout<<"Name: "<<name<<endl;
}
};
int main(){
  Student s1(31,"Praniti")
  Student s2(30,"Pran")
  s1.display();
  cout<<endl;
  s2.display();
  return 0;
}
